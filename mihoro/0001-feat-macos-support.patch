-        format!("/run/user/{}", uid)
-    });
-    PathBuf::from(run_dir).join("mihoro-crontab")
+    let xdg_runtime_dir = env::var("XDG_RUNTIME_DIR").ok();
+    let tmpdir = env::var("TMPDIR").ok();
+    let root = resolve_runtime_root(
+        std::env::consts::OS,
+        xdg_runtime_dir.as_deref(),
+        tmpdir.as_deref(),
+    );
+    root.join("mihoro-crontab")
