From 9601971aad19a18508786521834ae443e798ea03 Mon Sep 17 00:00:00 2001
From: Chawye Hsu <su+git@chawyehsu.com>
Date: Thu, 16 Apr 2026 03:48:29 +0800
Subject: [PATCH 13/18] win32: window resize handling and screen redraw

Signed-off-by: Chawye Hsu <su+git@chawyehsu.com>
---
 src/winio.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/src/winio.c b/src/winio.c
index 47d4e3a..3d0e510 100644
--- a/src/winio.c
+++ b/src/winio.c
@@ -223,6 +223,13 @@ void read_keys_from(WINDOW *frame)
 #else
 		if (!the_window_resized)
 			input = wgetch(frame);
+
+		/* SIGWINCH is not available on Windows, so we simulate the effect of
+		 * the handler by checking for PDCurses's KEY_RESIZE. */
+		if (input == KEY_RESIZE) {
+			handle_sigwinch(0);
+		}
+
 		if (the_window_resized) {
 			regenerate_screen();
 			input = THE_WINDOW_RESIZED;
-- 
2.54.0.windows.1

