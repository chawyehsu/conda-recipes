From 3b7f88f2ed4da9a54662c0f01993f49cc881b8db Mon Sep 17 00:00:00 2001
From: Chawye Hsu <su+git@chawyehsu.com>
Date: Thu, 16 Apr 2026 00:44:35 +0800
Subject: [PATCH 16/16] win32: pdcursesmod-ctrlv-passthrough

Signed-off-by: Chawye Hsu <su+git@chawyehsu.com>
---
 src/nano.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/src/nano.c b/src/nano.c
index 08492bc..a8e86c7 100644
--- a/src/nano.c
+++ b/src/nano.c
@@ -1840,6 +1840,13 @@ int main(int argc, char **argv)
 	 */
 	_set_fmode(_O_BINARY);
 
+#ifdef __PDCURSESMOD__
+	/* When using PDCursesMod, we want to disable the default Ctrl+V behavior of
+	 * pasting text from the system clipboard, so that Ctrl+V behaves as a normal
+	 * keystroke that paste text from nano's cutbuffer instead. */
+	PDC_set_function_key(FUNCTION_KEY_PASTE, 0);
+#endif
+
 #ifdef __linux__
 	struct vt_stat dummy;
 
-- 
