From 746d7e7809c8512db226ae6b751f07d53d692d6d Mon Sep 17 00:00:00 2001
From: Chawye Hsu <su+git@chawyehsu.com>
Date: Sun, 10 May 2026 14:51:25 +0800
Subject: [PATCH 17/18] win32: abort unsupported suspend function

Signed-off-by: Chawye Hsu <su+git@chawyehsu.com>
---
 src/nano.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/nano.c b/src/nano.c
index 7bdfb64..df0a54e 100644
--- a/src/nano.c
+++ b/src/nano.c
@@ -992,6 +992,11 @@ void do_suspend(void)
 	if (in_restricted_mode())
 		return;
 
+#if !defined(SIGTSTP)
+	statusline(AHEM, _("Suspension is not supported in this build"));
+	return;
+#endif
+
 	suspend_nano(0);
 
 	ran_a_tool = TRUE;
-- 
