From d7c64def97ee5f0647d614898077299c5b6170bc Mon Sep 17 00:00:00 2001
From: Chawye Hsu <su+git@chawyehsu.com>
Date: Thu, 16 Apr 2026 00:43:34 +0800
Subject: [PATCH 10/16] win32: remove-halfdelay-for-unicode

Signed-off-by: Chawye Hsu <su+git@chawyehsu.com>
---
 src/winio.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/src/winio.c b/src/winio.c
index 9e925f0..088b91c 100644
--- a/src/winio.c
+++ b/src/winio.c
@@ -201,9 +201,6 @@ void read_keys_from(WINDOW *frame)
 						lastmessage > HUSH && lastmessage < ALERT &&
 						lastmessage != INFO) || spotlighted)) {
 		timed = TRUE;
-		halfdelay(ISSET(QUICK_BLANK) ? 8 : 15);
-		/* Counteract a side effect of half-delay mode. */
-		disable_kb_interrupt();
 	}
 #endif
 
